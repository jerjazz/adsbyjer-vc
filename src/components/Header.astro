---
const calLink = "https://calendly.com/adsbyjer/30m?back=1";

const navLinks = [
  { label: "Results", href: "#results" },
  { label: "Services", href: "#services" },
  { label: "Process", href: "#process" },
  { label: "Free Audit", href: "#free-audit" },
  { label: "FAQ", href: "#faq" },
];
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500">
  <div class="container-tight">
    <nav class="flex items-center justify-between h-20 md:h-[5.5rem]" aria-label="Main navigation">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 text-decoration-none group" aria-label="Ads by Jer Home">
        <span class="text-[var(--text-heading)] font-semibold tracking-[0.15em] text-xs uppercase font-[Inter,sans-serif] transition-colors duration-300">
          Ads by Jer
        </span>
        <span class="hidden sm:inline-block w-px h-4" style="background: var(--border-primary);"></span>
        <span class="hidden sm:inline-block text-[var(--gold-600)] dark:text-[var(--gold-400)] text-[0.75rem] tracking-[0.08em] uppercase font-[Inter,sans-serif]">
          Venture Capital
        </span>
      </a>

      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center gap-6">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="text-[var(--text-secondary)] text-sm font-medium font-[Inter,sans-serif] hover:text-[var(--gold-600)] dark:hover:text-[var(--gold-400)] transition-all duration-300 no-underline hover:underline underline-offset-4 decoration-[var(--gold-500)]/40"
          >
            {link.label}
          </a>
        ))}

        <!-- Theme toggle -->
        <button class="theme-toggle" aria-label="Toggle dark mode">
          <svg class="theme-moon w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
          </svg>
          <svg class="theme-sun w-4 h-4" style="display:none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
          </svg>
        </button>

        <a href={calLink} target="_blank" rel="noopener noreferrer" class="btn-primary !py-2.5 !px-5 !text-[0.8rem]">
          Book a Call
        </a>
      </div>

      <!-- Mobile: Theme toggle + Hamburger -->
      <div class="flex md:hidden items-center gap-3">
        <button class="theme-toggle" aria-label="Toggle dark mode">
          <svg class="theme-moon w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
          </svg>
          <svg class="theme-sun w-4 h-4" style="display:none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
          </svg>
        </button>

        <button
          id="mobile-menu-btn"
          class="flex flex-col gap-1.5 p-2 -mr-2 bg-transparent border-none cursor-pointer"
          aria-label="Toggle menu"
        >
          <span class="block w-5 h-[2px] transition-all duration-300 origin-center" id="bar1" style="background: var(--text-body);"></span>
          <span class="block w-5 h-[2px] transition-all duration-300" id="bar2" style="background: var(--text-body);"></span>
          <span class="block w-5 h-[2px] transition-all duration-300 origin-center" id="bar3" style="background: var(--text-body);"></span>
        </button>
      </div>
    </nav>
  </div>

  <!-- Mobile Menu Overlay -->
  <div
    id="mobile-menu"
    class="md:hidden fixed inset-0 top-20 opacity-0 pointer-events-none transition-opacity duration-300 z-40"
    style="background-color: var(--overlay-bg); backdrop-filter: blur(20px);"
  >
    <div class="container-tight flex flex-col items-center justify-center gap-8 pt-20">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="mobile-nav-link text-[var(--text-heading)] text-xl font-medium font-[Inter,sans-serif] no-underline"
        >
          {link.label}
        </a>
      ))}
      <a href={calLink} target="_blank" rel="noopener noreferrer" class="btn-primary mt-4">
        Book a Strategy Call
      </a>
    </div>
  </div>
</header>
