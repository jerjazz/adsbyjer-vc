---
import Layout from "../layouts/Layout.astro";

const calLink = "https://calendly.com/adsbyjer/30m?back=1";

/* ── Data ── */

const metrics = [
  { value: "$30M+", label: "Ad Spend Managed Across Portfolios" },
  { value: "3.8x", label: "Average ROAS" },
  { value: "50+", label: "Portfolio Companies Scaled" },
  { value: "42%", label: "Avg CAC Reduction" },
];

const painPoints = [
  {
    number: "01",
    title: "Portfolio Companies Burning Cash with No Attribution",
    description:
      "Your companies hire junior marketers, hand them six-figure ad budgets, and hope for the best. No strategy. No attribution. No accountability. You find out when the next board deck shows a CAC that doubled.",
  },
  {
    number: "02",
    title: "The Agency Merry-Go-Round",
    description:
      "Every portfolio company cycles through agencies that overpromise, lock founders into 12-month contracts, and deliver reports full of impressions and clicks — not revenue. Switching costs compound every quarter.",
  },
  {
    number: "03",
    title: "Marketing Is a Board-Level Problem Nobody Owns",
    description:
      "Operating partners are stretched across 10 companies. Nobody has portfolio-wide visibility into marketing ROI. Every company reinvents the wheel, makes the same mistakes, and burns the same cash.",
  },
];

const services = [
  {
    title: "Google Ads",
    description:
      "Search, Shopping, and Performance Max campaigns engineered to capture high-intent demand the moment your portfolio company's ICP is looking for a solution. We optimize for pipeline, not clicks.",
    accent: "Capture Intent",
  },
  {
    title: "Meta & LinkedIn Ads",
    description:
      "Targeted demand-gen across Meta and LinkedIn that puts portfolio companies in front of decision-makers — with creative and audiences tested across similar companies in your portfolio.",
    accent: "Build Pipeline",
  },
  {
    title: "Landing Pages",
    description:
      "Conversion-optimized pages built for each company's ICP. No templates. No Unbounce drag-and-drop. Custom builds that turn paid traffic into pipeline with 2-3x higher conversion rates.",
    accent: "Convert Traffic",
  },
  {
    title: "Growth Analytics",
    description:
      "Full-funnel attribution from click to closed-won revenue. Portfolio-level dashboards that show operating partners exactly where the money goes — and what it returns.",
    accent: "Prove ROI",
  },
];

const caseStudies = [
  {
    category: "B2B SaaS",
    stage: "Series A",
    headline: "52% CAC Reduction in 90 Days",
    metrics: [
      { value: "52%", label: "Lower CAC" },
      { value: "3.4x", label: "Pipeline Growth" },
      { value: "90", label: "Days to Results" },
    ],
    channel: "Google Ads + LinkedIn",
    description:
      "A Series A SaaS company was burning $80K/mo on ads with no pipeline attribution. We rebuilt their paid search strategy, launched LinkedIn for top-of-funnel, and cut CAC by more than half while tripling qualified pipeline.",
  },
  {
    category: "DTC / E-commerce",
    stage: "Seed",
    headline: "ROAS From 1.2x to 4.8x",
    metrics: [
      { value: "4.8x", label: "ROAS" },
      { value: "280%", label: "Revenue Growth" },
      { value: "$0", label: "Wasted Spend" },
    ],
    channel: "Meta Ads + Google Shopping",
    description:
      "A seed-stage DTC brand was barely breaking even on Meta. We restructured creative testing, built a Shopping engine, and scaled revenue 280% — while maintaining profitable unit economics.",
  },
  {
    category: "FinTech",
    stage: "Series B",
    headline: "185% More SQLs, 41% Lower Cost",
    metrics: [
      { value: "185%", label: "More SQLs" },
      { value: "41%", label: "Lower CPL" },
      { value: "6 wks", label: "To Impact" },
    ],
    channel: "Google Ads + Landing Pages",
    description:
      "A Series B FinTech needed to scale SQLs for an enterprise push. We built dedicated landing pages per persona, restructured their Google Ads for SQL volume, and delivered 185% more qualified leads at 41% lower cost.",
  },
];

const steps = [
  {
    number: "01",
    title: "Audit",
    description:
      "We analyze your portfolio company's ad accounts, landing pages, conversion data, and attribution stack. You get a clear-eyed assessment: what's working, what's wasting money, and where the leverage is.",
  },
  {
    number: "02",
    title: "Deploy",
    description:
      "We launch high-performance campaigns in 2 weeks. Google, Meta, LinkedIn — whatever channels fit the company's ICP and stage. No 6-week onboarding. No strategy decks that gather dust.",
  },
  {
    number: "03",
    title: "Scale",
    description:
      "We optimize relentlessly against revenue data, not vanity metrics. Transparent reporting to you and the founders. When it works, we scale it. When it doesn't, we kill it fast and reallocate.",
  },
];

const audiences = [
  {
    title: "VC Partners",
    desc: "Who need portfolio companies to hit growth milestones before the next raise — and want a reliable marketing partner they can deploy, not another vendor to manage.",
  },
  {
    title: "Operating Partners",
    desc: "Who are tired of plugging the same marketing gaps across every company. Deploy one partner, get portfolio-wide visibility, and free up time for higher-leverage work.",
  },
  {
    title: "Platform Teams",
    desc: "Looking for a vetted growth partner to offer portfolio companies as a value-add service — with proven results across B2B SaaS, DTC, and FinTech.",
  },
  {
    title: "VC-Backed Founders",
    desc: "With board pressure to show efficient growth. Skip the agency roulette and work with a team that's scaled 50+ companies just like yours.",
  },
];

const faqItems = [
  {
    question: "How is this different from hiring an agency for each portfolio company?",
    answer: "Traditional agencies optimize for one company in isolation. We optimize across your portfolio — sharing learnings, benchmarks, and playbooks between companies. One partner, one relationship, consistent execution across 5, 10, or 50 companies. Operating partners get portfolio-wide reporting instead of reconciling data from a dozen different agencies.",
  },
  {
    question: "What does a typical engagement look like?",
    answer: "We start with a portfolio-level audit to identify the highest-impact opportunities. From there, we deploy to individual companies in 2-week sprints. Most portfolio engagements start with 2-3 companies and expand as results compound. Each company gets a custom strategy based on their stage, ICP, and growth targets.",
  },
  {
    question: "Do you require long-term contracts?",
    answer: "No. We work month-to-month after an initial 90-day onboarding period per company. We earn your business every month with transparent reporting tied to revenue — not vanity metrics. If we're not driving results, you should be able to leave. That's the accountability we believe in.",
  },
  {
    question: "What ad spend levels do you typically manage?",
    answer: "We work with portfolio companies spending $10K-$500K+/month on paid media. The right budget depends on the company's stage, market, and growth targets. During our audit, we'll recommend the right level and show you exactly what kind of returns to expect based on companies at a similar stage.",
  },
  {
    question: "How do you report results at the fund level?",
    answer: "Operating partners and platform teams get a portfolio-wide dashboard showing CAC, ROAS, pipeline, and revenue metrics across all engaged companies. Individual founders get detailed channel-level reporting. Every dollar is tracked from click to closed revenue — no vanity metrics, no black boxes.",
  },
  {
    question: "Can you work alongside existing marketing teams?",
    answer: "Absolutely. We frequently augment in-house marketers who are strong on brand and content but need paid media expertise. We integrate with their tools, join their standups, and function as an extension of their team — not a competing silo.",
  },
  {
    question: "What is a paid media audit for VC portfolio companies?",
    answer: "A paid media audit is a diagnostic review of a portfolio company's ad accounts, attribution stack, landing pages, and budget allocation. We assess 10 key areas — from CAC trends to creative testing velocity — and score each on a 1-5 scale. Companies scoring below 25 out of 50 typically have critical gaps that are burning cash. The audit takes 2 weeks and produces an actionable roadmap, not a generic slide deck.",
  },
  {
    question: "How much does it cost to hire a fractional growth marketing team for startups?",
    answer: "Our portfolio engagements start at $5K-$15K per company per month depending on the scope and number of channels. The cost is typically 30-50% less than hiring a full-time growth marketer, and you get a senior team rather than a single junior hire. Most portfolio discounts apply when engaging 3+ companies. We're month-to-month with no setup fees after the initial 90-day onboarding period.",
  },
];

/* ── Schema — Enhanced for SEO/AEO/GEO ── */

const siteUrl = "https://vc.adsbyjer.com";

const pageSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      "url": siteUrl,
      "name": "Ads by Jer – VC Growth Marketing",
      "description": "Performance marketing partner for venture capital and private equity firms. Portfolio-wide paid media management with $30M+ managed and 42% avg CAC reduction.",
      "publisher": { "@id": `${siteUrl}/#organization` },
      "inLanguage": "en-US",
    },
    {
      "@type": "Organization",
      "@id": `${siteUrl}/#organization`,
      "name": "Ads by Jer",
      "alternateName": "Ads by Jer – VC Growth Marketing",
      "url": siteUrl,
      "logo": `${siteUrl}/favicon.svg`,
      "email": "jer@adsbyjer.com",
      "telephone": "+16509449904",
      "description": "Fractional growth marketing team for venture capital portfolios. We deploy proven paid media strategies across portfolio companies — Google Ads, Meta Ads, LinkedIn Ads, landing page optimization, and full-funnel attribution.",
      "areaServed": {
        "@type": "Country",
        "name": "United States"
      },
      "knowsAbout": [
        "VC Portfolio Marketing",
        "Startup Growth Marketing",
        "Customer Acquisition Cost Optimization",
        "B2B SaaS Paid Media",
        "DTC Performance Marketing",
        "FinTech Growth Strategy",
        "Portfolio Company Scaling",
        "Performance Marketing for Venture Capital",
        "Private Equity Value Creation",
        "Paid Media Audits for Investors"
      ],
    },
    {
      "@type": "ProfessionalService",
      "@id": `${siteUrl}/#service`,
      "name": "Ads by Jer – Portfolio Paid Media Management",
      "provider": { "@id": `${siteUrl}/#organization` },
      "url": siteUrl,
      "telephone": "+16509449904",
      "email": "jer@adsbyjer.com",
      "areaServed": "US",
      "serviceType": [
        "Paid Media Management for VC Portfolio Companies",
        "Google Ads Management for Startups",
        "Meta Ads Management for Startups",
        "LinkedIn Ads Management for B2B SaaS",
        "Landing Page Design and Optimization",
        "Growth Analytics and Revenue Attribution",
        "Portfolio-Wide Marketing Strategy",
        "Fractional CMO for VC-Backed Companies"
      ],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Growth Marketing Services",
        "itemListElement": services.map((s, i) => ({
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": s.title,
            "description": s.description,
          },
          "position": i + 1,
        }))
      },
    },
    {
      "@type": "WebPage",
      "@id": `${siteUrl}/#webpage`,
      "url": siteUrl,
      "name": "VC Growth Marketing – Paid Media for Portfolio Companies | Ads by Jer",
      "isPartOf": { "@id": `${siteUrl}/#website` },
      "about": { "@id": `${siteUrl}/#service` },
      "description": "Performance marketing partner for venture capital and private equity firms. Deploy proven paid media strategies across your portfolio — $30M+ managed, 42% average CAC reduction, month-to-month engagements.",
      "breadcrumb": { "@id": `${siteUrl}/#breadcrumb` },
      "inLanguage": "en-US",
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": ["#hero-heading", "#hero-subheading", ".faq-trigger", ".faq-answer"]
      },
    },
    {
      "@type": "BreadcrumbList",
      "@id": `${siteUrl}/#breadcrumb`,
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": siteUrl
        }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqItems.map(item => ({
        "@type": "Question",
        "name": item.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": item.answer
        }
      }))
    }
  ]
};
---

<Layout
  title="Paid Media for VC Portfolio Companies — $30M+ Managed, 42% Avg CAC Reduction | Ads by Jer"
  description="Fractional growth marketing for venture capital & private equity portfolios. Google Ads, Meta Ads, LinkedIn — deployed across your portfolio companies. $30M+ managed, 42% avg CAC reduction, month-to-month."
  schema={pageSchema}
>
  <!-- ═══════════════════════════════════════════
       HERO
  ═══════════════════════════════════════════ -->
  <section class="relative overflow-hidden" aria-label="Hero">
    <div class="absolute inset-0 hero-grid-pattern"></div>
    <div class="absolute inset-0 hero-radial"></div>

    <div class="container-tight relative z-10 text-center pt-32 md:pt-40 pb-12 md:pb-16">
      <div class="animate-on-scroll">
        <p class="eyebrow eyebrow-centered mb-4">Portfolio Growth Marketing</p>
        <span class="block w-12 h-px mx-auto mt-4 mb-2" style="background: linear-gradient(90deg, transparent, var(--gold-500), transparent);"></span>
      </div>

      <h1 id="hero-heading" class="animate-on-scroll stagger-1 max-w-4xl mx-auto text-balance">
        Your Portfolio Companies Are Overspending on
        <span class="gold-text">Paid Media</span>
      </h1>

      <p id="hero-subheading" class="animate-on-scroll stagger-2 mt-8 text-lg md:text-xl text-[var(--text-secondary)] max-w-2xl mx-auto leading-relaxed">
        We deploy proven paid media strategies across VC portfolios.
        <strong class="text-[var(--text-heading)] font-semibold">$30M+ managed. 42% avg CAC reduction. Month-to-month.</strong>
      </p>

      <div class="animate-on-scroll stagger-3 mt-12 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href={calLink} target="_blank" rel="noopener noreferrer" class="btn-primary">
          Book a Strategy Call
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M6 12L10 8L6 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="#results" class="btn-secondary">
          See Results
        </a>
      </div>
    </div>

    <!-- Social Proof — Logo Bar (inside hero) -->
    <div class="relative z-10 border-t border-[var(--border-primary)] pb-10 md:pb-14" style="background: transparent;">
      <div class="container-tight pt-10 md:pt-12">
        <div class="text-center text-[0.7rem] font-medium tracking-[0.18em] uppercase mb-8 text-[var(--text-muted)] font-[Inter,sans-serif]">
          Trusted by teams backed by Sequoia, a16z, Kleiner Perkins & more
        </div>
        <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-6 md:gap-x-12 lg:gap-x-14">
          <div class="logo-item flex items-center gap-2">
            <img src="/logos/doordash.svg" alt="DoorDash logo" class="logo-icon h-5 w-5" loading="lazy" />
            <span class="logo-wordmark text-[0.95rem] md:text-[1.05rem] font-bold tracking-[-0.03em]">DoorDash</span>
          </div>
          <div class="logo-item flex items-center gap-2">
            <img src="/logos/lyft.svg" alt="Lyft logo" class="logo-icon h-5 w-5" loading="lazy" />
            <span class="logo-wordmark text-[0.95rem] md:text-[1.05rem] font-bold tracking-[-0.02em]">Lyft</span>
          </div>
          <div class="logo-item flex items-center gap-2">
            <img src="/logos/postmates.svg" alt="Postmates logo" class="logo-icon h-5 w-5" loading="lazy" />
            <span class="logo-wordmark text-[0.95rem] md:text-[1.05rem] font-bold tracking-[-0.03em]">Postmates</span>
          </div>
          <div class="logo-item flex items-center gap-2">
            <img src="/logos/harvey.svg" alt="Harvey.ai logo" class="logo-icon h-5 w-5" loading="lazy" />
            <span class="logo-wordmark text-[0.95rem] md:text-[1.05rem] font-semibold tracking-[-0.01em]">Harvey</span>
          </div>
          <div class="logo-item flex items-center gap-2">
            <img src="/logos/contentful.svg" alt="Contentful logo" class="logo-icon h-5 w-5" loading="lazy" />
            <span class="logo-wordmark text-[0.95rem] md:text-[1.05rem] font-semibold tracking-[-0.01em]">Contentful</span>
          </div>
          <div class="logo-item flex items-center gap-2">
            <img src="/logos/cultureamp.svg" alt="Culture Amp logo" class="logo-icon h-5 w-5" loading="lazy" />
            <span class="logo-wordmark text-[0.95rem] md:text-[1.05rem] font-semibold tracking-[-0.02em]">Culture Amp</span>
          </div>
          <div class="logo-item flex items-center gap-2">
            <img src="/logos/pebl.svg" alt="Pebl logo" class="logo-icon h-5 w-5" loading="lazy" />
            <span class="logo-wordmark text-[0.95rem] md:text-[1.05rem] font-semibold tracking-[-0.01em]">Pebl</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       METRICS BAR
  ═══════════════════════════════════════════ -->
  <section class="border-b border-[var(--border-primary)]" style="background: var(--bg-secondary);" aria-label="Key metrics">
    <div class="container-tight py-14 md:py-18">
      <dl class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-0">
        {metrics.map((m, i) => (
          <div class={`text-center animate-on-scroll stagger-${i + 1} ${i > 0 ? 'md:border-l md:border-[var(--border-primary)]' : ''}`}>
            <dt class="metric-label order-2">{m.label}</dt>
            <dd class="metric-number gold-text order-1">{m.value}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       PROBLEM
  ═══════════════════════════════════════════ -->
  <section class="section-padding" aria-label="The problem">
    <div class="container-tight">
      <div class="max-w-3xl animate-on-scroll">
        <p class="eyebrow mb-4">The Problem</p>
        <h2 class="text-balance">
          Your Portfolio Is
          <span class="gold-text">Bleeding Cash</span> on Marketing
        </h2>
        <p class="mt-5 text-[var(--text-secondary)] text-lg max-w-2xl leading-relaxed">
          You've seen it across the portfolio. The same patterns, the same waste, the same excuses — company after company.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-14">
        {painPoints.map((point, i) => (
          <div class={`card animate-on-scroll stagger-${i + 1}`}>
            <span class="text-[var(--gold-600)] dark:text-[var(--gold-400)] text-[0.85rem] font-bold font-[Inter,sans-serif] tracking-wide">{point.number}</span>
            <h3 class="mt-3 text-xl">{point.title}</h3>
            <p class="mt-3 text-[var(--text-secondary)] text-sm leading-relaxed">{point.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       SOLUTION
  ═══════════════════════════════════════════ -->
  <section class="section-padding border-y border-[var(--border-primary)]" style="background: var(--bg-secondary);" aria-label="The solution">
    <div class="container-tight">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="animate-on-scroll">
          <p class="eyebrow mb-4">The Solution</p>
          <h2 class="text-balance">
            One Growth Partner.<br />
            <span class="gold-text">Every Portfolio Company.</span>
          </h2>
          <p class="mt-6 text-[var(--text-secondary)] text-lg leading-relaxed">
            Deploy a fractional growth marketing team across your entire portfolio.
            Full-funnel paid media, conversion-optimized landing pages, and
            reporting that ties every dollar to revenue — not impressions.
          </p>
          <a href={calLink} target="_blank" rel="noopener noreferrer" class="btn-primary mt-8 inline-flex">
            Let's Talk
          </a>

          <!-- Social proof callout -->
          <div class="mt-10 pt-8 border-t border-[var(--border-primary)]">
            <div class="flex items-center gap-3">
              <div class="flex -space-x-2">
                <div class="w-8 h-8 rounded-full border-2 border-[var(--bg-secondary)] flex items-center justify-center text-[0.6rem] font-bold font-[Inter,sans-serif]" style="background: var(--gold-500); color: var(--bg-dark);">50+</div>
              </div>
              <p class="text-sm text-[var(--text-secondary)] leading-snug">
                <strong class="text-[var(--text-heading)]">50+ portfolio companies</strong> scaled across B2B SaaS, DTC, and FinTech
              </p>
            </div>
          </div>
        </div>

        <div class="space-y-5">
          {[
            { title: "Deploy Across Portfolio", desc: "One partner, consistent execution across multiple companies. Shared learnings, shared benchmarks. No re-training, no re-onboarding." },
            { title: "Revenue-Tied Reporting", desc: "No vanity metrics. Every report connects spend to CAC, pipeline, and closed revenue — at the company and fund level." },
            { title: "Month-to-Month. No Lock-In.", desc: "We earn your business every month. No 12-month contracts, no cancellation fees. Stay because it works." },
            { title: "2-Week Launch, Not 2 Months", desc: "Startups can't wait. We audit, strategize, and launch campaigns in 14 days flat. Not 14 weeks." },
          ].map((item, i) => (
            <div class={`animate-on-scroll stagger-${i + 1} flex items-start gap-4 p-6 rounded-xl border border-[var(--border-primary)] bg-[var(--bg-primary)] hover:border-[var(--border-hover)] transition-all duration-300`} style="box-shadow: var(--card-shadow);">
              <div class="w-2 h-2 rounded-full bg-[var(--gold-500)] mt-2.5 shrink-0"></div>
              <div>
                <h4 class="text-[var(--text-heading)] font-semibold text-base" style="font-family: Inter, sans-serif;">{item.title}</h4>
                <p class="text-sm text-[var(--text-secondary)] mt-1.5 leading-relaxed">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       SERVICES
  ═══════════════════════════════════════════ -->
  <section id="services" class="section-padding" aria-label="Services">
    <div class="container-tight">
      <div class="text-center max-w-2xl mx-auto animate-on-scroll">
        <p class="eyebrow eyebrow-centered mb-4">What We Do</p>
        <h2 class="text-balance">
          Full-Funnel Paid Media.<br />
          <span class="gold-text">Built for Scale.</span>
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-14">
        {services.map((service, i) => (
          <div class={`card animate-on-scroll stagger-${i + 1} group relative overflow-hidden`}>
            <div class="absolute top-0 left-0 right-0 h-[2px]" style="background: linear-gradient(90deg, var(--gold-500), var(--gold-300));"></div>
            <span class="text-[var(--gold-600)] dark:text-[var(--gold-400)] text-xs font-semibold tracking-[0.12em] uppercase font-[Inter,sans-serif]">{service.accent}</span>
            <h3 class="mt-3">{service.title}</h3>
            <p class="mt-3 text-[var(--text-secondary)] text-sm leading-relaxed">{service.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       RESULTS — DARK CONTRAST BAND
  ═══════════════════════════════════════════ -->
  <section id="results" class="section-padding" style="background: var(--bg-dark);" aria-label="Results and case studies">
    <div class="container-tight">
      <div class="text-center max-w-2xl mx-auto animate-on-scroll">
        <p class="eyebrow eyebrow-centered mb-4" style="color: var(--gold-400);">Results</p>
        <h2 class="text-balance" style="color: var(--text-dark-heading);">
          Numbers That Earn Board Seats
        </h2>
        <p class="mt-4 text-lg" style="color: var(--text-dark-body);">
          Real outcomes from VC-backed companies we've scaled — not projections.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mt-14">
        {caseStudies.map((study, i) => (
          <article class={`animate-on-scroll stagger-${i + 1} rounded-xl overflow-hidden border border-white/12 hover:border-[var(--gold-500)]/40 transition-all duration-400 hover:shadow-[0_8px_32px_rgba(166,139,91,0.1)]`} style="background: var(--bg-dark-secondary);">
            <div class="px-6 pt-6 pb-4">
              <div class="flex items-center gap-2">
                <span class="text-xs font-semibold tracking-wide font-[Inter,sans-serif]" style="color: var(--gold-400);">{study.category}</span>
                <span style="color: var(--text-dark-muted);">&middot;</span>
                <span class="text-xs font-[Inter,sans-serif]" style="color: var(--text-dark-muted);">{study.stage}</span>
              </div>
              <h3 class="mt-2 text-lg" style="color: var(--text-dark-heading);">{study.headline}</h3>
            </div>

            <dl class="grid grid-cols-3 border-y border-white/8">
              {study.metrics.map((m) => (
                <div class="py-4 px-3 text-center">
                  <dd class="text-xl md:text-2xl font-bold font-[Inter,sans-serif]" style="font-variant-numeric: tabular-nums; color: var(--text-dark-heading);">{m.value}</dd>
                  <dt class="text-[0.65rem] uppercase tracking-wide font-medium font-[Inter,sans-serif] mt-1" style="color: var(--text-dark-muted);">{m.label}</dt>
                </div>
              ))}
            </dl>

            <div class="px-6 py-5">
              <p class="text-sm leading-relaxed" style="color: var(--text-dark-body);">{study.description}</p>
              <div class="mt-3 flex items-center gap-1.5">
                <span class="w-1 h-1 rounded-full" style="background: var(--gold-500);"></span>
                <span class="text-xs font-[Inter,sans-serif]" style="color: var(--text-dark-muted);">{study.channel}</span>
              </div>
            </div>
          </article>
        ))}
      </div>

      <!-- Social proof strip -->
      <div class="animate-on-scroll mt-16 pt-10 border-t border-white/8">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
          <div>
            <p class="text-2xl font-bold font-[Inter,sans-serif]" style="font-variant-numeric: tabular-nums; color: var(--text-dark-heading);">100%</p>
            <p class="text-xs uppercase tracking-wide font-medium font-[Inter,sans-serif] mt-1" style="color: var(--text-dark-muted);">Client Retention Rate (2024)</p>
          </div>
          <div>
            <p class="text-2xl font-bold font-[Inter,sans-serif]" style="font-variant-numeric: tabular-nums; color: var(--text-dark-heading);">14 Days</p>
            <p class="text-xs uppercase tracking-wide font-medium font-[Inter,sans-serif] mt-1" style="color: var(--text-dark-muted);">Avg Time to First Campaign</p>
          </div>
          <div>
            <p class="text-2xl font-bold font-[Inter,sans-serif]" style="font-variant-numeric: tabular-nums; color: var(--text-dark-heading);">$30M+</p>
            <p class="text-xs uppercase tracking-wide font-medium font-[Inter,sans-serif] mt-1" style="color: var(--text-dark-muted);">Total Ad Spend Managed</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       PROCESS
  ═══════════════════════════════════════════ -->
  <section id="process" class="section-padding border-t border-[var(--border-primary)]" style="background: var(--bg-secondary);" aria-label="Our process">
    <div class="container-tight">
      <div class="text-center max-w-2xl mx-auto animate-on-scroll">
        <p class="eyebrow eyebrow-centered mb-4">How It Works</p>
        <h2 class="text-balance">
          Three Steps. <span class="gold-text">Zero Waste.</span>
        </h2>
        <p class="mt-4 text-[var(--text-secondary)] text-lg">
          Your portfolio companies can't afford a 6-week onboarding.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-14 relative">
        <div class="hidden md:block absolute top-7 left-[16.67%] right-[16.67%] h-px" style="background: var(--border-primary);"></div>
        {steps.map((step, i) => (
          <div class={`animate-on-scroll stagger-${i + 1} text-center md:text-left relative`}>
            <div class="step-number">{step.number}</div>
            <h3 class="mt-2">{step.title}</h3>
            <p class="mt-3 text-[var(--text-secondary)] text-sm leading-relaxed">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       WHO THIS IS FOR
  ═══════════════════════════════════════════ -->
  <section class="py-16 md:py-20" style="background: var(--bg-primary);" aria-label="Who this is for">
    <div class="container-tight">
      <div class="animate-on-scroll text-center max-w-3xl mx-auto">
        <p class="eyebrow eyebrow-centered mb-4">Who This Is For</p>
        <h2 class="text-balance mb-10">
          Built for the People Who <span class="gold-text">Write the Checks</span>
        </h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 mt-4">
        {audiences.map((item, i) => (
          <div class={`animate-on-scroll stagger-${i + 1} p-6 rounded-xl border border-[var(--border-primary)] border-t-2 border-t-[var(--gold-500)] bg-[var(--bg-secondary)] text-center hover:border-[var(--border-hover)] hover:border-t-[var(--gold-400)] transition-all duration-300 hover:shadow-[var(--card-shadow-hover)] hover:-translate-y-1`} style="box-shadow: var(--card-shadow);">
            <h4 class="text-[var(--text-heading)] font-semibold text-sm" style="font-family: Inter, sans-serif;">{item.title}</h4>
            <p class="text-xs text-[var(--text-secondary)] mt-2 leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       FREE AUDIT TEMPLATE — FORM-GATED DOWNLOAD
  ═══════════════════════════════════════════ -->
  <section id="free-audit" class="section-padding border-t border-[var(--border-primary)]" style="background: var(--bg-primary);" aria-label="Free paid media audit template download">
    <div class="container-tight">
      <div class="max-w-4xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-14 items-center">
          <!-- Left: Value Prop -->
          <div class="animate-on-scroll">
            <p class="eyebrow mb-4">Free Resource</p>
            <h2 class="text-balance text-2xl md:text-3xl">
              Portfolio Paid Media
              <span class="gold-text">Audit Template</span>
            </h2>
            <p class="mt-4 text-[var(--text-secondary)] text-sm leading-relaxed">
              10 diagnostic questions to assess any portfolio company's paid media health in under 15 minutes. Score each company, identify gaps, and know exactly where to intervene.
            </p>
            <ul class="mt-5 space-y-2.5">
              {[
                "10 diagnostic questions with scoring criteria",
                "Instant health check for any portfolio company",
                "Used by operating partners at top-tier funds",
              ].map(item => (
                <li class="flex items-start gap-2.5 text-sm text-[var(--text-secondary)]">
                  <svg class="w-4 h-4 mt-0.5 shrink-0" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M13.5 4.5L6.5 11.5L2.5 7.5" stroke="var(--gold-500)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>

          <!-- Right: Form -->
          <div class="animate-on-scroll stagger-1">
            <div class="p-6 md:p-8 rounded-xl border border-[var(--border-primary)] bg-[var(--bg-secondary)]" style="box-shadow: var(--card-shadow);">
              <p class="text-center text-sm font-semibold text-[var(--text-heading)] font-[Inter,sans-serif] mb-1">
                Get the Free Audit Template
              </p>
              <p class="text-center text-xs text-[var(--text-muted)] mb-5">
                Delivered instantly to your inbox as a PDF.
              </p>

              <form
                name="audit-download"
                method="POST"
                action="/.netlify/functions/audit-submit"
                class="space-y-3"
              >
                <p class="hidden">
                  <label>Don't fill this out: <input name="bot-field" /></label>
                </p>

                <input
                  type="text"
                  name="name"
                  placeholder="Your Name"
                  required
                  class="form-input"
                />
                <input
                  type="email"
                  name="email"
                  placeholder="Work Email"
                  required
                  class="form-input"
                />
                <input
                  type="text"
                  name="firm"
                  placeholder="Fund / Firm Name"
                  class="form-input"
                />

                <button type="submit" class="btn-primary w-full !mt-4">
                  Download the Audit Template
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M8 3V11M8 11L4.5 7.5M8 11L11.5 7.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M3 13H13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                  </svg>
                </button>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       FAQ — with structured data for SEO/AEO
  ═══════════════════════════════════════════ -->
  <section id="faq" class="section-padding border-t border-[var(--border-primary)]" style="background: var(--bg-secondary);" aria-label="Frequently asked questions">
    <div class="container-tight">
      <div class="text-center max-w-2xl mx-auto animate-on-scroll">
        <p class="eyebrow eyebrow-centered mb-4">FAQ</p>
        <h2 class="text-balance">
          Questions We Get from <span class="gold-text">Fund Operators</span>
        </h2>
      </div>

      <div class="max-w-3xl mx-auto mt-14 space-y-5">
        {faqItems.map((item, i) => (
          <div class={`faq-item animate-on-scroll stagger-${Math.min(i + 1, 6)}`} data-open="false">
            <button class="faq-trigger" aria-expanded="false">
              <span>{item.question}</span>
              <svg class="faq-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="12" y1="5" x2="12" y2="19"></line>
                <line x1="5" y1="12" x2="19" y2="12"></line>
              </svg>
            </button>
            <div class="faq-content">
              <p class="faq-answer">{item.answer}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       FINAL CTA — DARK CONTRAST BAND
  ═══════════════════════════════════════════ -->
  <section class="section-padding relative overflow-hidden" style="background: var(--bg-dark);" aria-label="Get started">
    <div class="absolute inset-0 opacity-40" style="background: radial-gradient(ellipse 60% 50% at 50% 0%, rgba(166, 139, 91, 0.12) 0%, transparent 70%);"></div>

    <div class="container-tight relative z-10">
      <div class="max-w-3xl mx-auto text-center">
        <div class="animate-on-scroll">
          <div class="w-16 h-px mx-auto mb-8" style="background: linear-gradient(90deg, transparent, var(--gold-400), transparent);"></div>
          <h2 class="text-balance" style="color: var(--text-dark-heading);">
            Stop Burning Runway on Marketing That Doesn't Convert
          </h2>
          <div class="w-16 h-px mx-auto mt-8" style="background: linear-gradient(90deg, transparent, var(--gold-400), transparent);"></div>
        </div>

        <p class="animate-on-scroll stagger-1 mt-6 text-lg max-w-xl mx-auto" style="color: var(--text-dark-body);">
          30 minutes. No pitch deck. Just a direct conversation about what's
          working, what's not, and where the growth is.
        </p>

        <div class="animate-on-scroll stagger-2 mt-10">
          <a href={calLink} target="_blank" rel="noopener noreferrer" class="btn-gold text-base !py-4 !px-8">
            Book a Strategy Call
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M6 12L10 8L6 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>

        <p class="animate-on-scroll stagger-3 mt-6 text-sm" style="color: var(--text-dark-muted);">
          Or email directly:
          <a href="mailto:jer@adsbyjer.com" class="transition-colors no-underline hover:opacity-80" style="color: var(--gold-400);">
            jer@adsbyjer.com
          </a>
        </p>
      </div>

      <!-- Contact Form -->
      <div class="animate-on-scroll mt-20 max-w-lg mx-auto">
        <div class="gold-divider mb-12"></div>
        <p class="text-center text-sm mb-6" style="color: var(--text-dark-muted);">Prefer async? Drop us a note.</p>

        <form
          name="vc-inquiry"
          method="POST"
          action="/thank-you"
          data-netlify="true"
          netlify-honeypot="bot-field"
          class="space-y-4"
        >
          <input type="hidden" name="form-name" value="vc-inquiry" />
          <p class="hidden">
            <label>Don't fill this out: <input name="bot-field" /></label>
          </p>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <input
              type="text"
              name="name"
              placeholder="Your Name"
              required
              class="form-input-dark"
            />
            <input
              type="email"
              name="email"
              placeholder="Email"
              required
              class="form-input-dark"
            />
          </div>

          <input
            type="text"
            name="company"
            placeholder="Firm / Company Name"
            class="form-input-dark"
          />

          <textarea
            name="message"
            placeholder="Tell us about your portfolio's growth challenges..."
            rows="3"
            class="form-input-dark resize-none"
          ></textarea>

          <div class="text-center">
            <button type="submit" class="btn-gold w-full sm:w-auto">
              Send Message
            </button>
          </div>
        </form>
      </div>
    </div>
  </section>
</Layout>
